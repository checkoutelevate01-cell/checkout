# ══════════════════════════════════════════════════════════════
# PAGAR.ME — Checkout Transparente para Mentoria
# ══════════════════════════════════════════════════════════════
# Copie este arquivo para .env e preencha com seus dados reais.
# NUNCA suba o arquivo .env para o repositório.

# ── PAGAR.ME ──────────────────────────────────────────────────
# Chave de API (ak_test_... para testes | ak_live_... para produção)
PAGARME_API_KEY=ak_test_SuaChaveAqui

# ── PRODUTO ───────────────────────────────────────────────────
# Nome exibido no checkout
PRODUCT_NAME=Mentoria Estratégica Premium

# Preço em centavos (350000 = R$ 3.500,00)
PRODUCT_PRICE=350000

# Descrição interna (aparece nos relatórios Pagar.me)
PRODUCT_DESCRIPTION=Mentoria individual - 3 meses de acompanhamento

# Nome na fatura do cartão (máx. 13 caracteres, sem acentos)
STATEMENT_DESCRIPTOR=MENTORIA

# ── MENTOR ────────────────────────────────────────────────────
MENTOR_NAME=Katherine

# ── PARCELAMENTO ─────────────────────────────────────────────
# Número máximo de parcelas
MAX_INSTALLMENTS=12

# Parcelas isentas de juros (restante cobra juros via Pagar.me)
MAX_INSTALLMENTS_NO_INTEREST=12

# ── PIX ───────────────────────────────────────────────────────
# Tempo até o QR Code expirar (em segundos | 3600 = 1 hora)
PIX_EXPIRES_IN=3600

# ── BOLETO ───────────────────────────────────────────────────
# Prazo em dias corridos para vencimento do boleto
BOLETO_DUE_DAYS=3

# ── ELEVENLABS (TTS — áudio personalizado) ───────────────────
# Crie sua conta em https://elevenlabs.io (plano gratuito: 10k chars/mês)
# Após criar, vá em Profile > API Key

# Sua API Key do ElevenLabs
ELEVENLABS_API_KEY=

# ID da voz escolhida (acesse https://elevenlabs.io/voice-library para explorar)
# Dica: crie uma voz clonada da mentora para máximo impacto
ELEVENLABS_VOICE_ID=Z6kj6Yu7S8HM0ydysQ8A

# ── WHATSAPP (Evolution API) ──────────────────────────────────
# A notificação é enviada automaticamente após cada venda

# URL base do seu servidor Evolution API (sem barra no final)
# Ex: https://evolution.suaempresa.com.br
EVOLUTION_API_URL=https://projeto-01-evolution-api.v7gpug.easypanel.host/

# Nome da instância criada no Evolution API
EVOLUTION_INSTANCE=numero-teste

# API Key global do Evolution API (definida no seu servidor)
EVOLUTION_API_KEY=E4F1EB34622B-4E36-BC92-D4868A59F3C2

# Número do admin/mentor para receber notificação de nova venda
# Formato: apenas dígitos com DDD, ex: 11999999999
WHATSAPP_ADMIN=27997236313

# Número público da equipe que aparece no botão de contato (página Obrigado)
# Formato: apenas dígitos com DDD, ex: 11999999999
WHATSAPP_CONTACT=

# ── ADMIN ────────────────────────────────────────────────────
# Senha para acessar o painel admin em /admin
ADMIN_PASSWORD=andre123

# Segredo JWT para sessões do admin (gere uma string aleatória)
ADMIN_JWT_SECRET=andre

# ── SERVIDOR ─────────────────────────────────────────────────
PORT=3000
